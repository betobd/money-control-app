{
  "expo": {
    "name": "MoneyControlApp",
    "slug": "MoneyControlApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "moneycontrolapp",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.alber.moneycontrolapp",
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-sharing",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Money Control to use device biometrics for app unlock."
        }
      ],
      "expo-build-properties",
      "react-native-quick-crypto",
      "expo-image",
      "expo-splash-screen",
      "expo-status-bar",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
